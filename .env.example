# Flash-IDPS Docker Environment Configuration
# Copy this file to .env and adjust values as needed

# Jupyter Configuration
JUPYTER_PORT=8888
JUPYTER_TOKEN=
JUPYTER_ENABLE_LAB=yes

# Docker Image Settings
DOCKER_IMAGE=flash-idps
DOCKER_TAG=latest

# Resource Limits (adjust based on your system)
CPU_LIMIT=4.0
MEMORY_LIMIT=8G
MEMORY_RESERVATION=4G

# Volume Paths (relative to project root)
DATA_VOLUME=./data
MODELS_VOLUME=./models
OUTPUT_VOLUME=./output
NOTEBOOKS_VOLUME=./notebooks

# GPU Settings (for GPU-enabled version)
NVIDIA_VISIBLE_DEVICES=all
CUDA_VERSION=11.7

# Python Settings
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
