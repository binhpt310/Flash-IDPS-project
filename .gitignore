# ============================================
# Heavy folders - Datasets & Models & Env
# ============================================

# Datasets (44GB)
data/

# Virtual environment (5.3GB)
venv/
env/
.venv/

# Flash-IDS repo with trained weights (124MB)
Flash-IDS/

# PIDSMaker repo (72MB)
PIDSMaker/

# Output visualizations (337MB) - regenerate locally
output/

# ============================================
# Ignore all files inside nested git repos
# ============================================
# These are separate repos, tracked independently
Flash-IDS/**
!Flash-IDS/.gitignore
data/**
!data/.gitignore
PIDSMaker/**
!PIDSMaker/.gitignore

