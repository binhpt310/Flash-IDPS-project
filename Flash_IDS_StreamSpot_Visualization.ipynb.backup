    "        ('dir_sbin', {'type': 'Directory', 'path': '/usr/sbin', 'label': '/usr/sbin'}),\n",
    "        ('dir_var_lib', {'type': 'Directory', 'path': '/var/lib', 'label': '/var/lib'}),\n",
