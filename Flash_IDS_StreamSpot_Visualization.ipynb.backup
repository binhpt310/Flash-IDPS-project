    "    G.add_nodes_from(sockets)\n",
    "    \n",
    "    # Directory nodes\n",
    "    dirs = [\n",
    "        ('dir_tmp', {'type': 'Directory', 'path': '/tmp', 'label': '/tmp'}),\n",
    "        ('dir_tmp_hidden', {'type': 'Directory', 'path': '/tmp/.hidden', 'label': '/tmp/.hidden [ATTACK]'}),\n",
    "        ('dir_etc', {'type': 'Directory', 'path': '/etc', 'label': '/etc'}),\n",
    "        ('dir_var_log', {'type': 'Directory', 'path': '/var/log', 'label': '/var/log'}),\n",
    "        ('dir_home', {'type': 'Directory', 'path': '/home/user1', 'label': '/home/user1'}),\n",
    "        ('dir_root', {'type': 'Directory', 'path': '/root', 'label': '/root'}),\n",
