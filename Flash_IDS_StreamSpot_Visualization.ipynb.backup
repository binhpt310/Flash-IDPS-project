    "        ))\n",
    "    \n",
    "    attack_count = sum(1 for _, _, d in G.edges(data=True) if d.get('is_attack', False))\n",
    "    normal_count = G.number_of_edges() - attack_count\n",
    "    \n",
    "    fig.update_layout(\n",
    "        title=dict(\n",
    "            text=f'<b>Flash-IDS Provenance Graph - StreamSpot</b><br>'\n",
    "                 f'<sup>{G.number_of_nodes()} nodes | {G.number_of_edges()} edges ({attack_count} attack, {normal_count} normal) | Hover for details</sup>',\n",
    "            x=0.5, font=dict(size=14)\n",
    "        ),\n",
    "        showlegend=True,\n",
    "        legend=dict(x=0.02, y=0.98, bgcolor='rgba(255,255,255,0.9)', font=dict(size=10)),\n",
    "        scene=dict(\n",
    "            xaxis=dict(visible=False), yaxis=dict(visible=False), zaxis=dict(visible=False),\n",
    "            bgcolor='rgba(240,240,250,0.95)',\n",
    "            camera=dict(eye=dict(x=1.5, y=1.5, z=1.2)),\n",
