    "    # Memory nodes\n",
    "    memory = [\n",
    "        ('mem_exploit', {'type': 'Memory', 'path': '0xdeadbeef', 'label': 'exploit_code [ATTACK]'}),\n",
    "        ('mem_shellcode', {'type': 'Memory', 'path': '0xcafebabe', 'label': 'shellcode [ATTACK]'}),\n",
    "        ('mem_payload', {'type': 'Memory', 'path': '0x12345678', 'label': 'payload_data [ATTACK]'}),\n",
    "        ('mem_creds', {'type': 'Memory', 'path': '0xabcdef00', 'label': 'stolen_creds [ATTACK]'}),\n",
    "        ('mem_normal', {'type': 'Memory', 'path': '0x08048000', 'label': 'normal_app'}),\n",
    "    ]\n",
    "    G.add_nodes_from(memory)\n",
    "    \n",
    "    # Attack edges\n",
    "    attack_edges = [\n",
    "        ('ssh_attacker', 'sock_ssh', 'connect', True),\n",
    "        ('sock_ssh', 'sshd', 'read', True),\n",
    "        ('sshd', 'bash_root', 'fork', True),\n",
    "        ('bash_root', 'mem_exploit', 'mmap', True),\n",
    "        ('bash_root', 'mem_shellcode', 'mmap', True),\n",
    "        ('mem_exploit', 'mem_payload', 'write', True),\n",
    "        ('bash_root', 'find_cmd', 'fork', True),\n",
    "        ('find_cmd', 'etc_shadow', 'read', True),\n",
    "        ('find_cmd', 'ssh_keys', 'read', True),\n",
    "        ('find_cmd', 'user_data_1', 'read', True),\n",
