    "    )\n",
    "    \n",
    "    fig.show()\n",
    "    \n",
    "    # Export HTML\n",
    "    html_file = OUTPUT_DIR / 'provenance_graph_streamspot_interactive.html'\n",
    "    plot(fig, filename=str(html_file), auto_open=False)\n",
