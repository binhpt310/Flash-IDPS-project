    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ 3D interactive graph exported to: /home/admincsc/workspace/binh/Flash-IDPS-project/output/StreamSpot_Visualization/provenance_graph_streamspot_interactive.html\n",
      "\n",
      "📊 Graph Statistics:\n",
      "   Total nodes: 93\n",
      "   Total edges: 85\n",
      "   Node types: {'Process': 28, 'File': 40, 'Socket': 10, 'Directory': 10, 'Memory': 5}\n",
      "   Edge types: {'fork': 22, 'read': 29, 'write': 17, 'mmap': 3, 'execute': 5, 'connect': 9}\n",
      "   Attack edges: 46\n",
      "   Normal edges: 39\n",
      "   Graph density: 0.0099\n",
      "   Is DAG: False\n"
     ]
    }
   ],
   "source": [
    "# Interactive 3D Provenance Graph cho StreamSpot Dataset\n",
    "# Tạo graph visualization với 2D/3D toggle và export HTML\n",
    "import networkx as nx\n",
    "import numpy as np\n",
    "from collections import Counter\n",
    "\n",
    "try:\n",
    "    import plotly.graph_objects as go\n",
    "    from plotly.offline import plot\n",
    "    PLOTLY_AVAILABLE = True\n",
    "except ImportError:\n",
    "    PLOTLY_AVAILABLE = False\n",
    "    print(\"⚠️ Plotly not installed. Install with: pip install plotly\")\n",
    "\n",
    "if PLOTLY_AVAILABLE:\n",
    "    # Build provenance graph\n",
    "    G = nx.DiGraph()\n",
    "    \n",
    "    # Process nodes\n",
    "    processes = [\n",
    "        ('init', {'type': 'Process', 'exec': '/sbin/init', 'pid': '1', 'label': 'init'}),\n",
    "        ('sshd', {'type': 'Process', 'exec': '/usr/sbin/sshd', 'pid': '1024', 'label': 'sshd'}),\n",
    "        ('bash_root', {'type': 'Process', 'exec': '/bin/bash', 'pid': '2001', 'label': 'bash(root)'}),\n",
    "        ('bash_user', {'type': 'Process', 'exec': '/bin/bash', 'pid': '2002', 'label': 'bash(user)'}),\n",
    "        ('python_exp', {'type': 'Process', 'exec': '/usr/bin/python3', 'pid': '3001', 'label': 'python3'}),\n",
    "        ('wget', {'type': 'Process', 'exec': '/usr/bin/wget', 'pid': '3002', 'label': 'wget'}),\n",
    "        ('chmod', {'type': 'Process', 'exec': '/bin/chmod', 'pid': '3003', 'label': 'chmod'}),\n",
    "        ('nc', {'type': 'Process', 'exec': '/bin/nc', 'pid': '3004', 'label': 'netcat'}),\n",
    "        ('ssh_attacker', {'type': 'Process', 'exec': '/usr/bin/ssh', 'pid': '4001', 'label': 'ssh(ext)'}),\n",
    "        ('cron', {'type': 'Process', 'exec': '/usr/sbin/cron', 'pid': '1050', 'label': 'cron'}),\n",
    "        ('apache', {'type': 'Process', 'exec': '/usr/sbin/apache2', 'pid': '1100', 'label': 'apache2'}),\n",
    "        ('mysql', {'type': 'Process', 'exec': '/usr/sbin/mysqld', 'pid': '1200', 'label': 'mysqld'}),\n",
    "        ('find_cmd', {'type': 'Process', 'exec': '/usr/bin/find', 'pid': '3010', 'label': 'find'}),\n",
    "        ('tar_cmd', {'type': 'Process', 'exec': '/bin/tar', 'pid': '3011', 'label': 'tar'}),\n",
    "        ('gzip_cmd', {'type': 'Process', 'exec': '/bin/gzip', 'pid': '3012', 'label': 'gzip'}),\n",
    "        ('scp_cmd', {'type': 'Process', 'exec': '/usr/bin/scp', 'pid': '4002', 'label': 'scp'}),\n",
    "        ('cat_cmd', {'type': 'Process', 'exec': '/bin/cat', 'pid': '3020', 'label': 'cat'}),\n",
    "        ('grep_cmd', {'type': 'Process', 'exec': '/bin/grep', 'pid': '3021', 'label': 'grep'}),\n",
    "        ('awk_cmd', {'type': 'Process', 'exec': '/usr/bin/awk', 'pid': '3022', 'label': 'awk'}),\n",
    "        ('curl_cmd', {'type': 'Process', 'exec': '/usr/bin/curl', 'pid': '4003', 'label': 'curl'}),\n",
    "    ]\n",
    "    \n",
    "    # Add child processes\n",
    "    for i in range(5):\n",
    "        processes.append((f'apache_child_{i}', {\n",
    "            'type': 'Process', 'exec': '/usr/sbin/apache2',\n",
    "            'pid': f'{1101+i}', 'label': f'apache2[{i}]'\n",
    "        }))\n",
    "    \n",
    "    for i in range(3):\n",
    "        processes.append((f'mysql_thread_{i}', {\n",
    "            'type': 'Process', 'exec': '/usr/sbin/mysqld',\n",
    "            'pid': f'{1201+i}', 'label': f'mysqld[{i}]'\n",
    "        }))\n",
    "    \n",
    "    G.add_nodes_from(processes)\n",
    "    \n",
    "    # File nodes\n",
    "    files = [\n",
    "        ('etc_passwd', {'type': 'File', 'path': '/etc/passwd', 'label': '/etc/passwd'}),\n",
    "        ('etc_shadow', {'type': 'File', 'path': '/etc/shadow', 'label': '/etc/shadow'}),\n",
    "        ('etc_hosts', {'type': 'File', 'path': '/etc/hosts', 'label': '/etc/hosts'}),\n",
    "        ('ssh_config', {'type': 'File', 'path': '/etc/ssh/sshd_config', 'label': 'sshd_config'}),\n",
    "        ('ssh_keys', {'type': 'File', 'path': '/root/.ssh/authorized_keys', 'label': 'authorized_keys'}),\n",
    "        ('apache_conf', {'type': 'File', 'path': '/etc/apache2/apache2.conf', 'label': 'apache2.conf'}),\n",
    "        ('mysql_conf', {'type': 'File', 'path': '/etc/mysql/my.cnf', 'label': 'my.cnf'}),\n",
    "        ('mysql_data', {'type': 'File', 'path': '/var/lib/mysql/ibdata1', 'label': 'ibdata1'}),\n",
    "        ('webshell', {'type': 'File', 'path': '/var/www/html/shell.php', 'label': 'shell.php'}),\n",
    "        ('payload', {'type': 'File', 'path': '/tmp/.hidden/payload.sh', 'label': 'payload.sh'}),\n",
    "        ('backdoor', {'type': 'File', 'path': '/tmp/.hidden/backdoor', 'label': 'backdoor'}),\n",
    "        ('exfil_data', {'type': 'File', 'path': '/tmp/.hidden/exfil.tar.gz', 'label': 'exfil.tar.gz'}),\n",
    "        ('cron_job', {'type': 'File', 'path': '/etc/cron.d/.hidden_job', 'label': '.hidden_job'}),\n",
    "        ('bash_history', {'type': 'File', 'path': '/root/.bash_history', 'label': '.bash_history'}),\n",
    "        ('auth_log', {'type': 'File', 'path': '/var/log/auth.log', 'label': 'auth.log'}),\n",
    "        ('syslog', {'type': 'File', 'path': '/var/log/syslog', 'label': 'syslog'}),\n",
    "        ('apache_access', {'type': 'File', 'path': '/var/log/apache2/access.log', 'label': 'access.log'}),\n",
    "        ('apache_error', {'type': 'File', 'path': '/var/log/apache2/error.log', 'label': 'error.log'}),\n",
    "        ('user_data_1', {'type': 'File', 'path': '/home/user1/documents/report.pdf', 'label': 'report.pdf'}),\n",
    "        ('user_data_2', {'type': 'File', 'path': '/home/user1/.ssh/id_rsa', 'label': 'id_rsa'}),\n",
    "    ]\n",
    "    \n",
    "    for i in range(10):\n",
    "        files.append((f'user_file_{i}', {\n",
    "            'type': 'File', 'path': f'/home/user1/data/file_{i}.dat',\n",
    "            'label': f'file_{i}.dat'\n",
    "        }))\n",
    "    \n",
    "    for i in range(10):\n",
    "        files.append((f'sys_file_{i}', {\n",
    "            'type': 'File', 'path': f'/var/lib/system/data_{i}.bin',\n",
    "            'label': f'data_{i}.bin'\n",
    "        }))\n",
    "    \n",
    "    G.add_nodes_from(files)\n",
    "    \n",
    "    # Socket nodes\n",
    "    sockets = [\n",
    "        ('sock_ssh', {'type': 'Socket', 'path': '0.0.0.0:22', 'label': 'SSH:22'}),\n",
    "        ('sock_http', {'type': 'Socket', 'path': '0.0.0.0:80', 'label': 'HTTP:80'}),\n",
    "        ('sock_https', {'type': 'Socket', 'path': '0.0.0.0:443', 'label': 'HTTPS:443'}),\n",
    "        ('sock_mysql', {'type': 'Socket', 'path': '127.0.0.1:3306', 'label': 'MySQL:3306'}),\n",
    "        ('sock_ext1', {'type': 'Socket', 'path': '192.168.1.100:4444', 'label': 'EXT:4444 [ATTACK]'}),\n",
    "        ('sock_ext2', {'type': 'Socket', 'path': '10.0.0.50:8080', 'label': 'EXT:8080 [ATTACK]'}),\n",
    "        ('sock_ext3', {'type': 'Socket', 'path': '172.16.0.99:9999', 'label': 'EXT:9999 [ATTACK]'}),\n",
    "        ('sock_dns', {'type': 'Socket', 'path': '8.8.8.8:53', 'label': 'DNS:53'}),\n",
    "        ('sock_smtp', {'type': 'Socket', 'path': 'mail.server.com:25', 'label': 'SMTP:25'}),\n",
    "        ('sock_ftp', {'type': 'Socket', 'path': 'ftp.server.com:21', 'label': 'FTP:21 [ATTACK]'}),\n",
